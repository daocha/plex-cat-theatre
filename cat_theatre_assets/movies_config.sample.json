{
  "debug_enabled": false,
  "root": [
    "~/Movies",
    "~/TV"
  ],
  "private_folder": [
    "Private"
  ],
  "thumbs_dir": "./cache/thumbnails",
  "log_dir": "./logs",
  "port": 9245,
  "host": "0.0.0.0",
  "mount_script": "",
  "locale": "auto",
  "transcode": false,
  "on_demand_transcode": true,
  "on_demand_hls": true,
  "transcode_video_codec": "h264_videotoolbox",
  "auto_scan_on_start": false,
  "enable_plex_server": false,
  "plex": {
    "base_url": "http://127.0.0.1:32400",
    "token": "",
    "timeout_seconds": 8,
    "refresh_interval_seconds": 120,
    "prefer_transcode": false
  },
  "direct_playback": {
    "enabled": true,
    "audio_whitelist": [
      "aac",
      "mp3"
    ]
  },
  "private_passcode": "sha256:replace-with-your-passcode-hash"
}
